# Environment Variables Configuration

# Copy this file to .env and fill in your actual values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port (default: 5000)
PORT=5000

# Node environment (development, production, staging)
NODE_ENV=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB connection URI
# Local: mongodb://localhost:27017/shree_collection
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb://localhost:27017/shree_collection

# ============================================================================
# JWT CONFIGURATION
# ============================================================================

# JWT secret key (use a long, random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiration time (e.g., 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Client URL for CORS (frontend domain)
CLIENT_URL=http://localhost:5173

# ============================================================================
# CLOUDINARY CONFIGURATION
# ============================================================================

# Cloudinary cloud name
# Get from: https://cloudinary.com/console
CLOUDINARY_NAME=your_cloudinary_name

# Cloudinary API key
CLOUDINARY_API_KEY=your_api_key_here

# Cloudinary API secret
CLOUDINARY_API_SECRET=your_api_secret_here

# ============================================================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================================================

# SMTP host (e.g., smtp.gmail.com)
MAIL_HOST=smtp.gmail.com

# SMTP port (465 for SSL, 587 for TLS)
MAIL_PORT=587

# Email sender address
MAIL_USER=your_email@gmail.com

# Email password or app-specific password
# For Gmail: Use app password (2FA enabled accounts)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_PASS=your_app_specific_password

# ============================================================================
# PAYMENT GATEWAY CONFIGURATION (Cashfree)
# ============================================================================

# Cashfree App ID
# Get from: https://dashboard.cashfree.com/merchant
CASHFREE_APP_ID=your_app_id

# Cashfree Secret Key
CASHFREE_SECRET_KEY=your_secret_key

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Enable debug mode (true/false)
DEBUG=false

# API rate limit (requests per window)
RATE_LIMIT=100

# Rate limit window (in minutes)
RATE_LIMIT_WINDOW=15

# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit this file with actual values to version control
# 2. In production, use environment-specific .env files
# 3. Ensure all required variables are set before starting the server
# 4. For sensitive data in production, use a secrets management service
# 5. Rotate secrets regularly
# 6. Use strong, random values for JWT_SECRET

# ============================================================================
# QUICK SETUP GUIDE
# ============================================================================

# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. Save the file
# 4. Restart your server
# 5. Verify all variables are loaded: npm run dev

# ============================================================================
